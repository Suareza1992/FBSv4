
# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string for your MongoDB database.
# Local dev:  mongodb://localhost:27017/fitbysuarez
# Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net/fitbysuarez
MONGO_URI=mongodb://localhost:27017/fitbysuarez

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secret used to sign authentication tokens. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit the real value. Rotate before going to production.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_HEX_SECRET

# ─── Admin / Trainer Seed ──────────────────────────────────────────────────────
# Password for the initial trainer account (fitbysuarez@gmail.com).
# Only used on first server start when no trainer exists in the DB.
# Change immediately after first login.
ADMIN_SEED_PASSWORD=REPLACE_WITH_TEMPORARY_PASSWORD

# ─── App URL ───────────────────────────────────────────────────────────────────
# Public URL of the app — used in invite and password-reset email links.
# Local dev:  http://localhost:3000
# Production: https://fitbysuarez.com
APP_URL=http://localhost:3000

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origin for API requests. Should match APP_URL in most setups.
CORS_ORIGIN=http://localhost:3000

# ─── Gmail SMTP ────────────────────────────────────────────────────────────────
# Gmail account used to send invite, password-reset, and welcome emails.
# Use a Google App Password (not your Google account password):
#   Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Debug (optional) ──────────────────────────────────────────────────────────
# Set to 'true' locally to enable verbose logging (email config, notifications).
# Never set to 'true' in production.
DEBUG=false
