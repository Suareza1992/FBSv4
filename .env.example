
# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string for your MongoDB database.
# Local dev:  mongodb://localhost:27017/fitbysuarez
# Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net/fitbysuarez
MONGO_URI=mongodb://localhost:27017/fitbysuarez

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secret used to sign authentication tokens. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit the real value. Rotate before going to production.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_HEX_SECRET

# ─── Admin / Trainer Seed ──────────────────────────────────────────────────────
# Password for the initial trainer account (fitbysuarez@gmail.com).
# Only used on first server start when no trainer exists in the DB.
# Change immediately after first login.
ADMIN_SEED_PASSWORD=REPLACE_WITH_TEMPORARY_PASSWORD

# ─── App URL ───────────────────────────────────────────────────────────────────
# Public URL of the app — used in invite and password-reset email links.
# Local dev:  http://localhost:3000
# Production: https://fitbysuarez.com
APP_URL=http://localhost:3000

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origin for API requests. Should match APP_URL in most setups.
CORS_ORIGIN=http://localhost:3000

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# All transactional email (invites, password resets, welcome, invoices) is sent
# via the Resend HTTP API — SMTP is avoided because Railway blocks it.
# Get a key at resend.com → API Keys. The from address is noreply@fitbysuarez.com
# (its domain must be verified in your Resend account).
RESEND_API_KEY=re_your_resend_api_key_here

# Trainer's email address — used as the sender/recipient on a few notification
# emails (not for SMTP auth).
GMAIL_USER=coach@example.com

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Debug (optional) ──────────────────────────────────────────────────────────
# Set to 'true' locally to enable verbose logging (email config, notifications).
# Never set to 'true' in production.
DEBUG=false

# --- Cloudinary -----------------------------------------------------------------
# Used for progress photo storage. Get these from cloudinary.com -> Dashboard.
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# --- Anthropic (AI meal recommender) --------------------------------------------
# Powers the "¿Qué como?" meal suggestions on the nutrition page.
# Create a key at console.anthropic.com -> API Keys. Leave blank to disable the feature.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Feature flag — set to "false" to keep the recommender hidden until launch.
MEAL_SUGGESTION_ENABLED=true
# Cost caps: per-client per-day limit, and a hard global monthly call cap (shared by
# the recommender AND the "Describir" food parser). At Haiku rates (~$0.005/call)
# 3000 ≈ $15/mo. Also set a $20 spend limit in the Anthropic Console.
MEAL_DAILY_LIMIT=5
MEAL_MONTHLY_LIMIT=3000
# Natural-language food logging ("Describir" tab). Separate on/off flag + its own daily cap.
FOOD_NLP_ENABLED=true
FOOD_NLP_DAILY_LIMIT=20
# Trainer's "Revisar equipo" workout check. Separate flag + per-trainer daily cap.
EQUIPMENT_CHECK_ENABLED=true
EQUIPMENT_CHECK_DAILY_LIMIT=50

# ─── Food data APIs ────────────────────────────────────────────────────────────
# Used by the food search. The app falls back to its curated local database when
# these are unset, so they're optional.
# USDA FoodData Central — free key at fdc.nal.usda.gov/api-key-signup.html ('DEMO_KEY' works for light use).
USDA_API_KEY=DEMO_KEY
# Nutritionix (optional) — fitness-grade food DB. Free keys at developer.nutritionix.com.
NUTRITIONIX_APP_ID=your_nutritionix_app_id_here
NUTRITIONIX_APP_KEY=your_nutritionix_app_key_here

# ─── Stripe (payments) ─────────────────────────────────────────────────────────
# Card payments. Use sk_test_... while testing, sk_live_... in production.
# Leave blank to disable Stripe (ATH Móvil / Venmo / PayPal links still work).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Webhook signing secret (whsec_...) from your Stripe dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
